rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Tenants & sub-collections (existing) ──────────────────────────────
    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == tenantId;

      match /events/{eventId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == tenantId;

        match /waitlist/{docId} {
          allow read, write: if true;
        }
      }

      match /guests/{guestId} {
        allow read: if request.auth != null && request.auth.uid == tenantId;
        allow write: if true; // ticket buyers write their own guest record
      }

      match /campaigns/{campaignId} {
        allow read, write: if request.auth != null && request.auth.uid == tenantId;
      }

      match /promo_codes/{codeId} {
        allow read: if true;  // public read so buyers can validate codes
        allow write: if request.auth != null && request.auth.uid == tenantId;
      }
    }

    // ── Global tickets collection ──────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read: if true;   // buyers look up by email on My Tickets
      allow create: if true; // payment response page writes the ticket
      allow update, delete: if request.auth != null;
    }

    // ── Blog posts ────────────────────────────────────────────────────────
    match /blog_posts/{postId} {
      // Anyone can read published posts
      allow read: if resource.data.published == true || request.auth != null;
      // Only authenticated users (admins) can create/edit/delete
      allow write: if request.auth != null;
    }
  }
}
